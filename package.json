{
  "name": "barcode-label-studio",
  "version": "1.2.9",
  "description": "Barcode Label Studio - Zebra label printing, Excel import, offline licensing and automatic updates.",
  "author": "AA Fast IT Solutions <aafastitsolutions@gmail.com>",
  "main": "main.js",
  "scripts": {
    "postinstall": "node tools/copy-libs.js",
    "start": "node scripts/start-electron.js",
    "dist": "electron-builder",
    "publish:github": "electron-builder --publish always",
    "make-keys": "node tools/make-keys.js",
    "make-license": "node tools/make-license.js",
    "license-ui": "electron tools/license-ui-main.js",
    "pack-client": "node scripts/pack-client.js",
    "license-server": "node server/license-server.js"
  },
  "dependencies": {
    "bwip-js": "^4.7.0",
    "electron-updater": "^6.8.3",
    "node-machine-id": "^1.1.12",
    "tweetnacl": "^1.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ro.valentin.barcodelabelstudio",
    "productName": "Barcode Label Studio",
    "artifactName": "Barcode-Label-Studio-Setup-${version}.${ext}",
    "icon": "build/icon.ico",
    "files": [
      "index.html",
      "main.js",
      "styles/**",
      "src/**",
      "libs/**",
      "scripts/start-electron.js"
    ],
    "publish": {
      "provider": "github",
      "owner": "aafastitsolutions",
      "repo": "Barcodelabel",
      "releaseType": "release"
    },
    "electronUpdaterCompatibility": ">=2.16",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "shortcutName": "Barcode Label Studio",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
