LICENSE_SERVER_PORT=8787
CORS_ORIGIN=*

# Cheia privata din tools/keys.json -> secretKeyB64.
# Nu pune aceasta valoare in GitHub si nu o include in aplicatia desktop.
BLS_LICENSE_SECRET_KEY_B64=PASTE_SECRET_KEY_B64_HERE

# Secretul configurat in Lemon Squeezy -> Settings -> Webhooks.
LEMON_WEBHOOK_SECRET=PASTE_WEBHOOK_SIGNING_SECRET_HERE

# Daca Lemon Squeezy nu trimite expires_at, serverul foloseste mapping-ul de variante.
# Inlocuieste ID-urile cu variant_id din Lemon Squeezy.
LEMON_VARIANT_MONTHS_JSON={"111111":1,"222222":6,"333333":12}
LEMON_VARIANT_PLANS_JSON={"111111":"PRO_1M","222222":"PRO_6M","333333":"PRO_12M"}

DEFAULT_LICENSE_MONTHS=12
LICENSE_GRACE_DAYS=0
